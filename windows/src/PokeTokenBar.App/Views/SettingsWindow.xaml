<Window
    x:Class="PokeTokenBar.App.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PokeTokenBar 설정"
    Width="380"
    Height="600"
    Background="{StaticResource WindowBackgroundBrush}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Manual"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Foreground="{StaticResource PrimaryTextBrush}"
            Text="사용량 설정" />

        <TextBlock
            Grid.Row="1"
            Margin="0,8,0,18"
            Foreground="{StaticResource SecondaryTextBrush}"
            Text="Claude Code 로컬 로그의 표시 항목과 자동 새로고침 간격을 선택합니다."
            TextWrapping="Wrap" />

        <StackPanel Grid.Row="2">
            <CheckBox
                x:Name="ShowTokensCheckBox"
                Margin="0,0,0,10"
                Foreground="{StaticResource PrimaryTextBrush}"
                Content="툴팁에 오늘 토큰 표시" />
            <CheckBox
                x:Name="ShowCostCheckBox"
                Margin="0,0,0,10"
                Foreground="{StaticResource PrimaryTextBrush}"
                Content="툴팁에 오늘 비용 표시" />
            <CheckBox
                x:Name="ShowLimitCheckBox"
                Foreground="{StaticResource PrimaryTextBrush}"
                Content="툴팁에 한도 표시" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,20,0,0">
            <TextBlock
                Margin="0,0,0,7"
                Foreground="{StaticResource PrimaryTextBrush}"
                Text="자동 새로고침" />
            <ComboBox x:Name="RefreshIntervalComboBox" Width="150" HorizontalAlignment="Left">
                <ComboBoxItem Tag="0">수동</ComboBoxItem>
                <ComboBoxItem Tag="60">1분</ComboBoxItem>
                <ComboBoxItem Tag="120">2분</ComboBoxItem>
                <ComboBoxItem Tag="300">5분</ComboBoxItem>
                <ComboBoxItem Tag="900">15분</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,18,0,0">
            <CheckBox
                x:Name="LimitNotificationsCheckBox"
                Margin="0,0,0,9"
                Foreground="{StaticResource PrimaryTextBrush}"
                Content="한도 경고 알림" />
            <CheckBox
                x:Name="StatusChecksCheckBox"
                Margin="0,0,0,9"
                Foreground="{StaticResource PrimaryTextBrush}"
                Content="프로바이더 상태 확인" />
            <CheckBox
                x:Name="DisableClaudeLimitsCheckBox"
                Margin="0,0,0,10"
                Foreground="{StaticResource PrimaryTextBrush}"
                Content="Claude 공식 한도 조회 끄기" />
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="65" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="65" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Text="경고 %" />
                <TextBox x:Name="WarnThresholdTextBox" Grid.Column="1" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Text="위험 %" />
                <TextBox x:Name="CritThresholdTextBox" Grid.Column="4" />
            </Grid>
            <TextBlock Margin="0,0,0,5" Foreground="{StaticResource PrimaryTextBrush}" Text="Codex 실행 파일(선택)" />
            <TextBox x:Name="CodexPathTextBox" Margin="0,0,0,10" />
            <Button
                Width="150"
                HorizontalAlignment="Left"
                Click="ReloadClaudeLimitsButton_OnClick"
                Content="Claude 토큰 다시 읽기" />
        </StackPanel>

        <StackPanel
            Grid.Row="5"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Margin="0,0,8,0"
                Click="CancelButton_OnClick"
                Content="취소" />
            <Button
                Width="80"
                Click="SaveButton_OnClick"
                Content="저장"
                IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
