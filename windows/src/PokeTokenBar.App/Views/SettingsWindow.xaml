<Window
    x:Class="PokeTokenBar.App.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PokeTokenBar 설정"
    Width="380"
    Height="390"
    Background="{StaticResource WindowBackgroundBrush}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Manual"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Foreground="{StaticResource PrimaryTextBrush}"
            Text="사용량 설정" />

        <TextBlock
            Grid.Row="1"
            Margin="0,8,0,18"
            Foreground="{StaticResource SecondaryTextBrush}"
            Text="Claude Code 로컬 로그의 표시 항목과 자동 새로고침 간격을 선택합니다."
            TextWrapping="Wrap" />

        <StackPanel Grid.Row="2">
            <CheckBox
                x:Name="ShowTokensCheckBox"
                Margin="0,0,0,10"
                Foreground="{StaticResource PrimaryTextBrush}"
                Content="툴팁에 오늘 토큰 표시" />
            <CheckBox
                x:Name="ShowCostCheckBox"
                Margin="0,0,0,10"
                Foreground="{StaticResource PrimaryTextBrush}"
                Content="툴팁에 오늘 비용 표시" />
            <CheckBox
                x:Name="ShowLimitCheckBox"
                Foreground="{StaticResource PrimaryTextBrush}"
                Content="툴팁에 한도 표시" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,20,0,0">
            <TextBlock
                Margin="0,0,0,7"
                Foreground="{StaticResource PrimaryTextBrush}"
                Text="자동 새로고침" />
            <ComboBox x:Name="RefreshIntervalComboBox" Width="150" HorizontalAlignment="Left">
                <ComboBoxItem Tag="0">수동</ComboBoxItem>
                <ComboBoxItem Tag="60">1분</ComboBoxItem>
                <ComboBoxItem Tag="120">2분</ComboBoxItem>
                <ComboBoxItem Tag="300">5분</ComboBoxItem>
                <ComboBoxItem Tag="900">15분</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <StackPanel
            Grid.Row="5"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Margin="0,0,8,0"
                Click="CancelButton_OnClick"
                Content="취소" />
            <Button
                Width="80"
                Click="SaveButton_OnClick"
                Content="저장"
                IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
