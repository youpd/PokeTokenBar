<Window
    x:Class="PokeTokenBar.App.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PokeTokenBar Settings"
    Width="480"
    Height="760"
    Background="{StaticResource WindowBackgroundBrush}"
    ResizeMode="CanMinimize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="22">
        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <TextBlock x:Name="TitleText" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="Settings" />

                <TextBlock x:Name="GeneralHeader" Margin="0,20,0,8" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="General" />
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="190" /></Grid.ColumnDefinitions>
                    <TextBlock x:Name="LanguageLabel" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Text="Language" />
                    <ComboBox x:Name="LanguageComboBox" Grid.Column="1">
                        <ComboBoxItem Tag="ko">한국어</ComboBoxItem>
                        <ComboBoxItem Tag="en">English</ComboBoxItem>
                        <ComboBoxItem Tag="ja">日本語</ComboBoxItem>
                    </ComboBox>
                </Grid>
                <Grid Margin="0,9,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="190" /></Grid.ColumnDefinitions>
                    <TextBlock x:Name="RefreshLabel" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Text="Refresh interval" />
                    <ComboBox x:Name="RefreshIntervalComboBox" Grid.Column="1">
                        <ComboBoxItem Tag="0">Manual</ComboBoxItem><ComboBoxItem Tag="60">1 min</ComboBoxItem>
                        <ComboBoxItem Tag="120">2 min</ComboBoxItem><ComboBoxItem Tag="300">5 min</ComboBoxItem>
                        <ComboBoxItem Tag="900">15 min</ComboBoxItem>
                    </ComboBox>
                </Grid>
                <CheckBox x:Name="AutoStartCheckBox" Margin="0,12,0,0" Foreground="{StaticResource PrimaryTextBrush}" Content="Launch at login" />

                <TextBlock x:Name="TrayHeader" Margin="0,20,0,8" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="Tray display" />
                <CheckBox x:Name="ShowTokensCheckBox" Margin="0,0,0,7" Foreground="{StaticResource PrimaryTextBrush}" Content="Today's tokens" />
                <CheckBox x:Name="ShowCostCheckBox" Margin="0,0,0,7" Foreground="{StaticResource PrimaryTextBrush}" Content="Today's cost" />
                <CheckBox x:Name="ShowLimitCheckBox" Margin="0,0,0,9" Foreground="{StaticResource PrimaryTextBrush}" Content="Limit %" />
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="190" /></Grid.ColumnDefinitions>
                    <TextBlock x:Name="NumericIconLabel" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Text="Numeric tray icon" />
                    <ComboBox x:Name="NumericTrayIconComboBox" Grid.Column="1">
                        <ComboBoxItem Tag="">Character</ComboBoxItem><ComboBoxItem Tag="tokens">Tokens</ComboBoxItem>
                        <ComboBoxItem Tag="cost">Cost</ComboBoxItem><ComboBoxItem Tag="limit">Limit %</ComboBoxItem>
                    </ComboBox>
                </Grid>

                <TextBlock x:Name="NotificationsHeader" Margin="0,20,0,8" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="Notifications" />
                <CheckBox x:Name="LimitNotificationsCheckBox" Margin="0,0,0,7" Foreground="{StaticResource PrimaryTextBrush}" Content="Limit alerts" />
                <CheckBox x:Name="CompanionNotificationsCheckBox" Margin="0,0,0,7" Foreground="{StaticResource PrimaryTextBrush}" Content="Companion events" />
                <CheckBox x:Name="StatusChecksCheckBox" Margin="0,0,0,7" Foreground="{StaticResource PrimaryTextBrush}" Content="Provider status checks" />
                <CheckBox x:Name="UpdateNotificationsCheckBox" Margin="0,0,0,10" Foreground="{StaticResource PrimaryTextBrush}" Content="Show update banner" />
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="65" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /><ColumnDefinition Width="65" /></Grid.ColumnDefinitions>
                    <TextBlock x:Name="WarnLabel" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Text="Warning %" />
                    <TextBox x:Name="WarnThresholdTextBox" Grid.Column="1" />
                    <TextBlock x:Name="CriticalLabel" Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" Text="Critical %" />
                    <TextBox x:Name="CritThresholdTextBox" Grid.Column="4" />
                </Grid>

                <TextBlock x:Name="AdvancedHeader" Margin="0,20,0,8" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="Advanced" />
                <CheckBox x:Name="DisableClaudeLimitsCheckBox" Margin="0,0,0,9" Foreground="{StaticResource PrimaryTextBrush}" Content="Disable Claude official limits" />
                <TextBlock x:Name="CodexPathLabel" Margin="0,0,0,5" Foreground="{StaticResource PrimaryTextBrush}" Text="Codex executable (optional)" />
                <TextBox x:Name="CodexPathTextBox" Margin="0,0,0,9" />
                <TextBlock x:Name="ExtraHomesLabel" Margin="0,0,0,5" Foreground="{StaticResource PrimaryTextBrush}" Text="Extra home directories (one per line)" />
                <TextBox x:Name="ExtraHomesTextBox" Height="56" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                <Button x:Name="ReloadClaudeLimitsButton" Width="180" Margin="0,10,0,0" HorizontalAlignment="Left" Click="ReloadClaudeLimitsButton_OnClick" Content="Reload Claude credential" />
                <TextBlock x:Name="AggregationNoteText" Margin="0,10,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="Token basis: input + output + cache, local date." TextWrapping="Wrap" />

                <TextBlock x:Name="UpdatesHeader" Margin="0,20,0,8" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="Updates" />
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="CheckUpdatesButton" Width="140" Click="CheckUpdatesButton_OnClick" Content="Check now" />
                    <TextBlock x:Name="UpdateResultText" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SecondaryTextBrush}" Text="" />
                </StackPanel>

                <TextBlock x:Name="SupportHeader" Margin="0,20,0,8" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="About &amp; Support" />
                <WrapPanel>
                    <Button x:Name="ReportProblemButton" Margin="0,0,7,7" Click="ReportProblemButton_OnClick" Content="Report a problem" />
                    <Button x:Name="ShowLogsButton" Margin="0,0,7,7" Click="ShowLogsButton_OnClick" Content="Show logs" />
                    <Button x:Name="GitHubButton" Margin="0,0,7,7" Click="GitHubButton_OnClick" Content="GitHub" />
                </WrapPanel>
                <TextBlock x:Name="VersionText" Margin="0,4,0,18" Foreground="{StaticResource SecondaryTextBrush}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Margin="0,14,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button x:Name="CancelButton" Width="84" Margin="0,0,8,0" Click="CancelButton_OnClick" Content="Cancel" />
            <Button x:Name="SaveButton" Width="84" Click="SaveButton_OnClick" Content="Save" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
