<Window
    x:Class="PokeTokenBar.App.Views.FlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PokeTokenBar"
    Width="420"
    Height="780"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">
    <Border
        Margin="8"
        Padding="16"
        Background="{DynamicResource WindowBackgroundBrush}"
        BorderBrush="#33404A5A"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.36" ShadowDepth="4" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="PokeTokenBar" />
                    <TextBlock x:Name="SubtitleText" Foreground="{DynamicResource SecondaryTextBrush}" Text="AI usage companion" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ToggleButton
                        x:Name="PinButton"
                        Width="36"
                        Height="30"
                        Margin="0,0,6,0"
                        Background="#FF2A2E36"
                        BorderBrush="#FF4B5565"
                        Click="PinButton_OnClick"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        ToolTip="창 고정">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border
                                    x:Name="PinBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="PinBorder" Property="Background" Value="#FF355F4A" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="PinBorder" Property="Background" Value="#FF357A58" />
                                        <Setter TargetName="PinBorder" Property="BorderBrush" Value="#FF72E6AC" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                        <Viewbox Width="16" Height="16">
                            <Canvas Width="20" Height="20">
                                <Path
                                    Data="M7,1 L13,1 L13,3 L12,4 L12,8 L15,11 L15,13 L10.8,13 L10,19 L9,19 L8.2,13 L4,13 L4,11 L7,8 L7,4 L6,3 L6,1 Z"
                                    Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>
                    <Button
                        x:Name="RefreshButton"
                        Width="36"
                        Height="30"
                        Background="#FF2A2E36"
                        BorderBrush="#FF4B5565"
                        Click="RefreshButton_OnClick"
                        FontSize="18"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        ToolTip="지금 새로고침">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border
                                    x:Name="RefreshBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="RefreshBorder" Property="Background" Value="#FF355F4A" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock FontFamily="Segoe UI Symbol" Text="↻" />
                    </Button>
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1" Margin="0,12,0,0" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#FF23262D" />
                        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                        <Setter Property="Padding" Value="13,7" />
                        <Setter Property="Margin" Value="0,0,3,0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border
                                        x:Name="TabBorder"
                                        Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="7">
                                        <ContentPresenter
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            ContentSource="Header" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#FF355F4A" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabItem x:Name="HomeTab" Header="Home">
                    <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border x:Name="UpdateBanner" Margin="0,0,0,10" Padding="10" Background="#44355F4A" BorderBrush="#FF4D9B70" BorderThickness="1" CornerRadius="9" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="UpdateBannerText" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}" TextWrapping="Wrap" />
                                    <Button x:Name="ApplyUpdateButton" Grid.Column="1" Margin="8,0,0,0" Padding="8,3" Click="ApplyUpdateButton_OnClick" Content="Update" />
                                    <Button x:Name="SkipUpdateButton" Grid.Column="2" Margin="5,0,0,0" Padding="8,3" Click="SkipUpdateButton_OnClick" Content="Skip" />
                                </Grid>
                            </Border>
                            <Border Padding="14" Background="#FF202832" CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="80" Height="80">
                                        <Image
                                            x:Name="CompanionSpriteImage"
                                            Width="76"
                                            Height="76"
                                            RenderOptions.BitmapScalingMode="NearestNeighbor"
                                            Stretch="Uniform">
                                            <Image.RenderTransform>
                                                <TranslateTransform x:Name="CompanionBobTransform" />
                                            </Image.RenderTransform>
                                        </Image>
                                        <TextBlock
                                            x:Name="CompanionEmojiText"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe UI Emoji"
                                            FontSize="54"
                                            Foreground="#FFFFE7A3"
                                            Text="🥚" />
                                    </Grid>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="CompanionNameText" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="Token Egg" />
                                        <TextBlock x:Name="CompanionMetaText" Margin="0,3,0,0" Foreground="{StaticResource AccentBrush}" Text="5M tokens to hatch" />
                                        <ProgressBar x:Name="CompanionProgressBar" Height="7" Margin="0,9,0,0" Maximum="100" />
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock x:Name="CompanionStatusText" Foreground="{StaticResource SecondaryTextBrush}" Text="Sleeping in the egg" />
                                            <TextBlock x:Name="CompanionProgressText" HorizontalAlignment="Right" Foreground="{StaticResource SecondaryTextBrush}" Text="0%" />
                                        </Grid>
                                        <TextBlock x:Name="CompanionLineText" Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Margin="0,10,0,0" Padding="14" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="TodayLabel" Foreground="{DynamicResource SecondaryTextBrush}" Text="오늘" />
                                        <TextBlock x:Name="TodayTokensText" Margin="0,3,0,0" FontSize="25" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="—" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                        <TextBlock x:Name="CostLabel" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}" Text="예상 비용" />
                                        <TextBlock x:Name="TodayCostText" Margin="0,3,0,2" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" Text="—" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Padding="12" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10">
                                    <StackPanel><TextBlock x:Name="WeekLabel" Foreground="{DynamicResource SecondaryTextBrush}" Text="이번 주" /><TextBlock x:Name="WeekTokensText" Margin="0,4,0,0" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Text="—" /></StackPanel>
                                </Border>
                                <Border Grid.Column="2" Padding="12" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10">
                                    <StackPanel><TextBlock x:Name="MonthLabel" Foreground="{DynamicResource SecondaryTextBrush}" Text="이번 달" /><TextBlock x:Name="MonthTokensText" Margin="0,4,0,0" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Text="—" /></StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="ProviderChipsContainer" Margin="0,10,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="ProvidersLabel" Margin="2,0,0,5" Foreground="{DynamicResource SecondaryTextBrush}" Text="프로바이더" />
                                <WrapPanel x:Name="ProviderChipsPanel" />
                            </StackPanel>

                            <Border Margin="0,10,0,0" Padding="12" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedProviderNameText" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="프로바이더 없음" />
                                        <TextBlock x:Name="SelectedProviderTodayText" Grid.Column="1" MaxWidth="390" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}" Text="—" />
                                    </Grid>
                                    <UniformGrid Margin="0,10,0,0" Columns="4">
                                        <StackPanel><TextBlock x:Name="InputLabel" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="입력" /><TextBlock x:Name="InputTokensText" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Text="—" /></StackPanel>
                                        <StackPanel><TextBlock x:Name="OutputLabel" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="출력" /><TextBlock x:Name="OutputTokensText" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Text="—" /></StackPanel>
                                        <StackPanel><TextBlock x:Name="CacheWriteLabel" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="캐시 생성" /><TextBlock x:Name="CacheWriteTokensText" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Text="—" /></StackPanel>
                                        <StackPanel><TextBlock x:Name="CacheReadLabel" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="캐시 읽기" /><TextBlock x:Name="CacheReadTokensText" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Text="—" /></StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border x:Name="StatusBanner" Margin="0,10,0,0" Padding="10" Background="#443B2C16" BorderBrush="#FFB7791F" BorderThickness="1" CornerRadius="9" Visibility="Collapsed">
                                <TextBlock x:Name="StatusBannerText" Foreground="#FFFFD28A" TextWrapping="Wrap" />
                            </Border>

                            <Border Margin="0,10,0,0" Padding="12" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock x:Name="CurrentBlockLabel" Foreground="{DynamicResource SecondaryTextBrush}" Text="선택 프로바이더 5시간 블록" /><TextBlock x:Name="BlockTokensText" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" Text="—" /></StackPanel>
                                    <TextBlock x:Name="BurnRateText" Grid.Column="1" VerticalAlignment="Bottom" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Grid>
                            </Border>

                            <Border x:Name="LimitSectionBorder" Margin="0,10,0,0" Padding="12" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10" Visibility="Collapsed">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock x:Name="LimitSectionTitle" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="공식 한도" />
                                        <Button x:Name="ReloadClaudeLimitsButton" Grid.Column="1" Padding="8,3" Click="ReloadClaudeLimitsButton_OnClick" Content="다시 읽기" Visibility="Collapsed" />
                                    </Grid>
                                    <TextBlock x:Name="LimitSectionMessage" Margin="0,6,0,0" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Visibility="Collapsed" />
                                    <StackPanel x:Name="LimitRowsPanel" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>
                            <TextBlock x:Name="RefreshStatusText" Margin="2,12,2,10" Foreground="{StaticResource SecondaryTextBrush}" Text="사용량 불러오는 중…" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="ShopTab" Header="Shop">
                    <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Padding="14" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12">
                                <StackPanel><TextBlock x:Name="WalletLabel" Foreground="{DynamicResource SecondaryTextBrush}" Text="사용 가능한 토큰" /><TextBlock x:Name="WalletText" Margin="0,4,0,0" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" Text="0" /></StackPanel>
                            </Border>
                            <StackPanel x:Name="ShopPanel" Margin="0,10,0,0" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="BagTab" Header="Bag">
                    <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="BagPanel" />
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="CollectionTab" Header="Collection">
                    <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock x:Name="CollectionSummaryText" Margin="2,0,0,8" Foreground="{StaticResource SecondaryTextBrush}" Text="Collection 0" />
                            <StackPanel x:Name="CollectionPanel" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
