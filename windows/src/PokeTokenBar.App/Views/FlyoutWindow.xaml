<Window
    x:Class="PokeTokenBar.App.Views.FlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PokeTokenBar"
    Width="400"
    Height="474"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">
    <Border
        Margin="8"
        Padding="20"
        Background="{StaticResource WindowBackgroundBrush}"
        BorderBrush="#33404A5A"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.36" ShadowDepth="4" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    FontFamily="Segoe UI Emoji"
                    FontSize="28"
                    Text="🥚" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        Text="PokeTokenBar" />
                    <TextBlock
                        Foreground="{StaticResource SecondaryTextBrush}"
                        Text="Claude Code 사용량" />
                </StackPanel>
                <Button
                    x:Name="RefreshButton"
                    Grid.Column="2"
                    Width="36"
                    Height="30"
                    Background="#FF2A2E36"
                    BorderBrush="#FF4B5565"
                    BorderThickness="1"
                    Click="RefreshButton_OnClick"
                    Content="↻"
                    FontSize="18"
                    Foreground="{StaticResource PrimaryTextBrush}"
                    ToolTip="지금 새로고침" />
            </Grid>

            <Separator Grid.Row="1" Margin="0,14,0,14" Opacity="0.25" />

            <Border
                Grid.Row="2"
                Padding="16"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            Foreground="{StaticResource SecondaryTextBrush}"
                            Text="오늘" />
                        <TextBlock
                            x:Name="TodayTokensText"
                            Margin="0,3,0,0"
                            FontSize="27"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            Text="—" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                        <TextBlock
                            HorizontalAlignment="Right"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            Text="예상 비용" />
                        <TextBlock
                            x:Name="TodayCostText"
                            Margin="0,3,0,2"
                            HorizontalAlignment="Right"
                            FontSize="16"
                            Foreground="{StaticResource AccentBrush}"
                            Text="—" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="14" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="이번 주" />
                        <TextBlock
                            x:Name="WeekTokensText"
                            Margin="0,5,0,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            Text="—" />
                    </StackPanel>
                </Border>
                <Border
                    Grid.Column="2"
                    Padding="14"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="이번 달" />
                        <TextBlock
                            x:Name="MonthTokensText"
                            Margin="0,5,0,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            Text="—" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                Grid.Row="4"
                Margin="0,10,0,0"
                Padding="14"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="현재 5시간 블록" />
                        <TextBlock
                            x:Name="BlockTokensText"
                            Margin="0,5,0,0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PrimaryTextBrush}"
                            Text="—" />
                    </StackPanel>
                    <TextBlock
                        x:Name="BurnRateText"
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        Text="" />
                </Grid>
            </Border>

            <TextBlock
                x:Name="RefreshStatusText"
                Grid.Row="5"
                Margin="2,14,2,0"
                VerticalAlignment="Bottom"
                Foreground="{StaticResource SecondaryTextBrush}"
                Text="사용량 불러오는 중…"
                TextTrimming="CharacterEllipsis" />
        </Grid>
    </Border>
</Window>
