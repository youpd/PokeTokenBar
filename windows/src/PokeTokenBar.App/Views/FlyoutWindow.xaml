<Window
    x:Class="PokeTokenBar.App.Views.FlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PokeTokenBar"
    Width="360"
    Height="188"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">
    <Border
        Margin="8"
        Padding="24"
        Background="{StaticResource WindowBackgroundBrush}"
        BorderBrush="#33404A5A"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.36" ShadowDepth="4" />
        </Border.Effect>
        <StackPanel VerticalAlignment="Center">
            <TextBlock
                HorizontalAlignment="Center"
                FontFamily="Segoe UI Emoji"
                FontSize="38"
                Text="🥚" />
            <TextBlock
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{StaticResource PrimaryTextBrush}"
                Text="PokeTokenBar" />
            <TextBlock
                Margin="0,5,0,0"
                HorizontalAlignment="Center"
                Foreground="{StaticResource SecondaryTextBrush}"
                Text="Windows 포팅 골격이 준비되었습니다." />
        </StackPanel>
    </Border>
</Window>
