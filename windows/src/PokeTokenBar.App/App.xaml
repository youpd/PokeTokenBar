<Application
    x:Class="PokeTokenBar.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF181A1F" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF23262D" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFF4F5F7" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FFB7BDC8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF72D6A0" />
    </Application.Resources>
</Application>
